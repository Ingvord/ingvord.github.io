---
const navLinks = [
  { href: '/talks/', label: 'Talks' },
  { href: '/publications/', label: 'Publications' },
  { href: '/trading-platform/', label: 'Case Study' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="wordmark" aria-label="Igor Khokhriakov — home">
      <span class="wordmark-name">Igor Khokhriakov</span>
      <span class="wordmark-role">Staff Software Engineer</span>
    </a>
    <div class="header-right">
      <nav aria-label="Primary navigation">
        <ul class="nav-list">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'nav-link--active': currentPath.startsWith(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <button id="theme-toggle" class="theme-btn" aria-label="Toggle light/dark theme" title="Toggle theme">
        <!-- Moon: shown in dark mode -->
        <svg class="icon icon-moon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
        </svg>
        <!-- Sun: shown in light mode -->
        <svg class="icon icon-sun hidden" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const root = document.documentElement;

  function getTheme(): 'dark' | 'light' {
    return root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
  }

  function setTheme(theme: 'dark' | 'light') {
    if (theme === 'light') {
      root.setAttribute('data-theme', 'light');
    } else {
      root.removeAttribute('data-theme');
    }
    localStorage.setItem('theme', theme);
    syncIcon(theme);
  }

  function syncIcon(theme: 'dark' | 'light') {
    toggle?.querySelector('.icon-moon')?.classList.toggle('hidden', theme === 'light');
    toggle?.querySelector('.icon-sun')?.classList.toggle('hidden', theme === 'dark');
  }

  toggle?.addEventListener('click', () => {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  });

  syncIcon(getTheme());
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--ink) 92%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding-block: 1rem;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    color: var(--text);
    text-decoration: none;
    line-height: 1.2;
  }

  .wordmark:hover {
    opacity: 1;
  }

  .wordmark-name {
    font-family: var(--font-display);
    font-stretch: expanded;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
  }

  .wordmark-role {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: 2rem;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.15s ease;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .nav-link--active {
    color: var(--trace);
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--trace);
  }

  .theme-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    border-radius: 4px;
    transition: color 0.15s ease;
    flex-shrink: 0;
  }

  .theme-btn:hover {
    color: var(--text);
  }

  .theme-btn:focus-visible {
    outline: 2px solid var(--trace);
    outline-offset: 2px;
  }

  .icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 480px) {
    .nav-list {
      gap: 1.25rem;
    }
    .wordmark-role {
      display: none;
    }
    .header-right {
      gap: 1rem;
    }
  }
</style>
